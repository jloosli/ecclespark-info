# Firebase config (only needed for production builds via inject-env.js)
# NG_FIREBASE_API_KEY=your-firebase-api-key
# NG_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NG_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
# NG_FIREBASE_APP_ID=your-app-id

# YouTube secrets are stored in Firebase Secret Manager (not env vars)
# See scripts/get-owner-token.ts for setup instructions
