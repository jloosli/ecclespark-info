rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /streams/{streamId} {
      allow read: if true;
      // Writes handled by Cloud Function via Admin SDK (bypasses rules)
      allow create, update, delete: if false;
    }
    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if false;
    }
    match /allowed_users/{email} {
      // Only accessible via Admin SDK (Cloud Functions)
      allow read, write: if false;
    }
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.fireCMSUser;
    }
  }
}
